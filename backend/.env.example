# =====================================================
# FLUXTURN - ENVIRONMENT CONFIGURATION
# =====================================================
# Copy this file to .env and fill in your values
# All values below are PLACEHOLDERS - replace before running
# =====================================================

# =====================================================
# DATABASE (PostgreSQL)
# =====================================================

# Primary platform database
PLATFORM_DB_HOST=localhost
PLATFORM_DB_PORT=5432
PLATFORM_DB_NAME=fluxturn_platform
PLATFORM_DB_USER=postgres
PLATFORM_DB_PASSWORD=changeme

# Legacy database variables (for backward compatibility)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=fluxturn_platform
DB_USER=postgres
DB_PASSWORD=changeme

# Tenant databases configuration
TENANT_DB_HOST=localhost
TENANT_DB_PORT=5432
TENANT_DB_USER=postgres
TENANT_DB_PASSWORD=changeme

# =====================================================
# SERVER
# =====================================================

PORT=5005
NODE_ENV=development
LOG_LEVEL=debug

# Auto-seeding (set to true to skip auto-seeding on startup)
SKIP_AUTO_SEED=false

# =====================================================
# AUTHENTICATION
# =====================================================

# JWT - REQUIRED: Generate a strong random secret
# Example: openssl rand -hex 64
JWT_SECRET=your-jwt-secret-change-me
JWT_EXPIRATION=7d

# Encryption key for connector credentials
# Generate with: openssl rand -hex 32
CONNECTOR_ENCRYPTION_KEY=your-encryption-key-change-me

# Session
SESSION_SECRET=your-session-secret-change-me
SESSION_TIMEOUT=86400000

# =====================================================
# VECTOR DATABASE (Qdrant)
# =====================================================

QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=your-qdrant-api-key

# =====================================================
# REDIS
# =====================================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password

# =====================================================
# CLOUD STORAGE (Cloudflare R2)
# =====================================================
# Optional: Required only if using cloud file storage

CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_R2_BUCKET_NAME=fluxturn-uploads
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-key
CLOUDFLARE_R2_PUBLIC_URL=https://cdn.yourdomain.com

# =====================================================
# AWS (SQS, SES)
# =====================================================
# Optional: Required only if using AWS services

AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1

# SQS queue configuration
SQS_QUEUE_PREFIX=fluxturn-dev

# =====================================================
# EMAIL (SMTP)
# =====================================================
# Configure your email provider (AWS SES, SendGrid, etc.)

MAIL_MAILER=smtp
MAIL_HOST=smtp.your-provider.com
MAIL_PORT=587
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-password
MAIL_FROM_ADDRESS=noreply@yourdomain.com
MAIL_FROM_NAME="FluxTurn"
EMAIL_DEFAULT_FROM=noreply@yourdomain.com

# =====================================================
# APPLICATION URLS
# =====================================================

APP_URL=http://localhost:5005
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:5005/api
SOCKET_SERVER_URL=http://localhost:3001
REALTIME_URL=ws://localhost:3001

# Invitation settings
INVITATION_BASE_URL=http://localhost:5173/invitations
INVITATION_EXPIRY_DAYS=7

# =====================================================
# FILE STORAGE (Local)
# =====================================================

UPLOAD_DESTINATION=./uploads
MAX_FILE_SIZE=10485760
MAX_UPLOAD_SIZE=10485760
TEMP_FILES_DIR=./temp

# =====================================================
# RATE LIMITING
# =====================================================

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
API_KEY_RATE_LIMIT_MAX_REQUESTS=1000

# =====================================================
# MONITORING & LOGGING
# =====================================================

ENABLE_METRICS=true
METRICS_PORT=9090
LOG_FORMAT=json
LOG_TO_FILE=false
LOG_FILE_PATH=./logs/fluxturn.log

# =====================================================
# SECURITY
# =====================================================

API_KEY_HASH_ALGORITHM=sha256
API_KEY_MIN_LENGTH=32
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL=true

# =====================================================
# FEATURE FLAGS
# =====================================================

ENABLE_NATURAL_LANGUAGE_QUERIES=true
ENABLE_MULTI_TENANT_ISOLATION=true
ENABLE_API_KEY_AUTH=true
ENABLE_JWT_AUTH=true
ENABLE_QUERY_CACHING=true
ENABLE_AUDIT_LOGGING=true

# =====================================================
# AI SERVICES
# =====================================================

AI_PROVIDER=openai
EMBEDDING_DEFAULT=openai
USE_ENHANCED_GENERATION=true
BUILD_ERROR_FIX_ENABLED=true
DETERMINISTIC_GENERATION=false
BYPASS_SUBSCRIPTION_LIMITS=false

# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini
OPENAI_REASONING_MODEL=gpt-4o-mini
OPENAI_GENERATING_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# DeepSeek (via OpenRouter) - optional, for code generation
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://openrouter.ai/api/v1
DEEPSEEK_MODEL=deepseek/deepseek-chat-v3-0324

# Code generation model selection (openai or deepseek)
CODE_GENERATION_PROVIDER=openai

# E2B Sandbox - optional, for code execution
E2B_API_KEY=your-e2b-api-key

# =====================================================
# SWAGGER / API DOCS
# =====================================================
# Swagger UI is available at /api/docs
# Set credentials to protect the docs endpoint

SWAGGER_USER=admin
SWAGGER_PASSWORD=your-swagger-password-change-me

# =====================================================
# DEPLOYMENT
# =====================================================

DEFAULT_DEPLOYMENT_METHOD=cloudflare
SITE_DOMAIN=yourdomain.com
MAIN_DOMAIN=yourdomain.com

# =====================================================
# OAUTH CONFIGURATIONS
# =====================================================
# Create OAuth apps with each provider and fill in your credentials
# All redirect URIs default to localhost for development

# --- Google OAuth ---
# Create at: https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5005/api/v1/oauth/google/callback

# --- LinkedIn OAuth ---
# Create at: https://www.linkedin.com/developers/apps
LINKEDIN_OAUTH_CLIENT_ID=your-linkedin-client-id
LINKEDIN_OAUTH_CLIENT_SECRET=your-linkedin-client-secret
LINKEDIN_OAUTH_REDIRECT_URI=http://localhost:5005/api/v1/oauth/linkedin/callback

# --- Facebook OAuth ---
# Create at: https://developers.facebook.com/apps
FACEBOOK_CLIENT_ID=your-facebook-client-id
FACEBOOK_CLIENT_SECRET=your-facebook-client-secret
FACEBOOK_REDIRECT_URI=http://localhost:5005/api/v1/oauth/facebook/callback

# --- Slack OAuth ---
# Create at: https://api.slack.com/apps
SLACK_OAUTH_CLIENT_ID=your-slack-client-id
SLACK_OAUTH_CLIENT_SECRET=your-slack-client-secret
SLACK_OAUTH_REDIRECT_URI=http://localhost:5005/api/v1/oauth/slack/callback

# --- Twitter/X OAuth ---
# Create at: https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
TWITTER_OAUTH_CLIENT_ID=your-twitter-client-id
TWITTER_OAUTH_CLIENT_SECRET=your-twitter-client-secret
TWITTER_OAUTH_REDIRECT_URI=http://localhost:5005/api/v1/oauth/twitter/callback

# --- Zoom OAuth ---
# Create at: https://marketplace.zoom.us/develop/create
ZOOM_ACCOUNT_ID=your-zoom-account-id
ZOOM_OAUTH_CLIENT_ID=your-zoom-client-id
ZOOM_OAUTH_CLIENT_SECRET=your-zoom-client-secret
ZOOM_OAUTH_REDIRECT_URI=http://localhost:5005/api/v1/oauth/zoom/callback

# --- GitHub OAuth ---
# Create at: https://github.com/settings/developers
GITHUB_OAUTH_CLIENT_ID=your-github-client-id
GITHUB_OAUTH_CLIENT_SECRET=your-github-client-secret
GITHUB_OAUTH_REDIRECT_URI=http://localhost:5005/api/v1/oauth/github/callback

# --- Discord OAuth ---
# Create at: https://discord.com/developers/applications
DISCORD_OAUTH_CLIENT_ID=your-discord-client-id
DISCORD_OAUTH_CLIENT_SECRET=your-discord-client-secret
DISCORD_OAUTH_REDIRECT_URI=http://localhost:5005/api/v1/oauth/discord/callback

# --- Reddit OAuth ---
# Create at: https://www.reddit.com/prefs/apps
REDDIT_OAUTH_CLIENT_ID=your-reddit-client-id
REDDIT_OAUTH_CLIENT_SECRET=your-reddit-client-secret
REDDIT_OAUTH_REDIRECT_URI=http://localhost:5005/api/v1/oauth/reddit/callback

# --- Shopify OAuth ---
# Create at: https://partners.shopify.com/
SHOPIFY_OAUTH_API_KEY=your-shopify-api-key
SHOPIFY_OAUTH_API_SECRET=your-shopify-api-secret
SHOPIFY_OAUTH_REDIRECT_URI=http://localhost:5005/api/v1/oauth/shopify/callback

# --- Pinterest OAuth ---
# Create at: https://developers.pinterest.com/apps/
PINTEREST_OAUTH_CLIENT_ID=your-pinterest-client-id
PINTEREST_OAUTH_CLIENT_SECRET=your-pinterest-client-secret
PINTEREST_OAUTH_REDIRECT_URI=http://localhost:5005/api/v1/oauth/pinterest/callback

# --- Microsoft Teams OAuth ---
# Create at: https://portal.azure.com/
MICROSOFT_TEAMS_OAUTH_CLIENT_ID=your-microsoft-teams-client-id
MICROSOFT_TEAMS_OAUTH_CLIENT_SECRET=your-microsoft-teams-client-secret
MICROSOFT_TEAMS_OAUTH_REDIRECT_URI=http://localhost:5005/api/v1/oauth/microsoft-teams/callback

# --- HubSpot OAuth ---
# Create at: https://developers.hubspot.com/
HUBSPOT_OAUTH_CLIENT_ID=your-hubspot-client-id
HUBSPOT_OAUTH_CLIENT_SECRET=your-hubspot-client-secret
HUBSPOT_OAUTH_REDIRECT_URI=http://localhost:5005/api/v1/oauth/hubspot/callback

# =====================================================
# SOCIAL MEDIA COOKIES (Optional - for scraping features)
# =====================================================
# Export cookies using browser extensions like "Cookie-Editor"

LINKEDIN_COOKIES=
FACEBOOK_COOKIES=
INSTAGRAM_COOKIES=
TWITTER_COOKIES=

# =====================================================
# STRIPE PAYMENT (Optional)
# =====================================================

STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# Stripe Price IDs (create in Stripe Dashboard)
STRIPE_PRICE_STARTER_MONTHLY=price_xxx
STRIPE_PRICE_STARTER_YEARLY=price_xxx
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_YEARLY=price_xxx
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_xxx
STRIPE_PRICE_ENTERPRISE_YEARLY=price_xxx
