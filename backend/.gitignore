# Dependencies
node_modules/
package-lock.json
yarn.lock

# Build output
dist/
build/
*.js
# Exception: Include template seeder scripts
!scripts/check-templates.js
!scripts/export-templates.js
!scripts/seed-templates.js
*.js.map
*.d.ts

# Environment files
.env
.env.local
.env.production
.env.*.local

# Sensitive credential files
info.txt
note.txt

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Testing
coverage/
.nyc_output/

# Temporary files
tmp/
temp/
uploads/

# Generated app structures (do not commit generated code)
generated-app-structure/

# Docker
.docker/

# Claude templates (source files - actual templates are in src/common/templates/)
.claude/templates/
.claude/TEMPLATE_GENERATION_SUMMARY.md
.claude/template-files-list.txt

# Scripts (except whitelisted ones)
!scripts/update-templates.js

# Database backups (never commit these)
db/backups/*.sql
