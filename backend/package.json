{
  "name": "@fluxturn/backend",
  "version": "1.0.0",
  "description": "FluxTurn - Workflow Automation Platform Backend with AI-powered workflow builder and 60+ connectors",
  "main": "dist/main.js",
  "scripts": {
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:restart": "npm run docker:down && npm run docker:up",
    "docker:logs": "docker compose logs -f",
    "docker:clean": "docker compose down -v",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=4096 nest build",
    "start": "node dist/main.js",
    "start:dev": "cross-env NODE_OPTIONS=--max-old-space-size=4096 nest start --watch",
    "start:debug": "cross-env NODE_OPTIONS=--max-old-space-size=4096 nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "dev": "npm run docker:up && npm run start:dev",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:orchestrated": "ts-node src/scripts/test-orchestrated-workflow.ts",
    "mcp:postgres": "node dist/mcp-servers/postgres-multi-tenant-server.js",
    "mcp:query": "node dist/mcp-servers/natural-language-query-server.js",
    "mcp:workflow": "node dist/mcp-servers/workflow-server.js",
    "mcp:brain": "node dist/mcp-servers/brain-agi-server.js",
    "site-logs": "ts-node src/cli/site-monitor.cli.ts logs",
    "site-status": "ts-node src/cli/site-monitor.cli.ts status",
    "site-stats": "ts-node src/cli/site-monitor.cli.ts stats",
    "site-suspend": "ts-node src/cli/site-monitor.cli.ts suspend",
    "site-wake": "ts-node src/cli/site-monitor.cli.ts wake",
    "site-cleanup": "ts-node src/cli/site-monitor.cli.ts cleanup",
    "site-monitor": "ts-node src/cli/site-monitor.cli.ts monitor",
    "site-metrics": "ts-node src/cli/site-monitor.cli.ts metrics",
    "dns-add": "ts-node src/cli/dns-manager.cli.ts add-main-site",
    "dns-verify": "ts-node src/cli/dns-manager.cli.ts verify",
    "dns-list": "ts-node src/cli/dns-manager.cli.ts list",
    "ssl-status": "ts-node src/cli/dns-manager.cli.ts ssl-status",
    "ssl-configure": "ts-node src/cli/dns-manager.cli.ts configure-ssl",
    "zone-info": "ts-node src/cli/dns-manager.cli.ts zone-info",
    "cache-purge": "ts-node src/cli/dns-manager.cli.ts purge-cache",
    "analyze-connectors": "ts-node src/scripts/analyze-connectors.ts",
    "seed:qdrant": "ts-node src/scripts/seed-qdrant.ts",
    "check:openai": "ts-node src/scripts/check-openai-models.ts",
    "seed": "npm run build && node dist/scripts/seed.js",
    "seed:connector": "ts-node src/scripts/seed-connector.ts",
    "seed:connectors": "ts-node src/scripts/seed-connectors.ts",
    "seed:templates": "node dist/src/scripts/seed-templates-standalone.js",
    "update:icons": "ts-node scripts/update-connector-icons.ts",
    "backup:db": "node scripts/backup-dev-database.js",
    "migrate": "ts-node src/scripts/migrate.ts",
    "migrate:status": "ts-node src/scripts/migrate.ts status"
  },
