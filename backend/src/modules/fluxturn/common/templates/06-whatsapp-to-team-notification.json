          "inputSchema": {
            "channel": {
              "type": "string",
              "required": true,
              "label": "Channel"
            },
            "message": {
              "type": "string",
              "required": true,
              "label": "Message",
              "inputType": "textarea"
            }
          },
          "configSchema": {
            "channel": {
              "type": "string",
              "required": true,
              "label": "Channel"
            },
            "message": {
              "type": "string",
              "required": true,
              "label": "Message",
