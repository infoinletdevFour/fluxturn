              "type": "string",
              "required": true,
              "label": "Spreadsheet ID"
            },
            "sheetName": {
              "type": "string",
              "label": "Sheet Name",
              "default": "Sheet1"
            },
            "values": {
              "type": "object",
              "required": true,
              "label": "Values"
