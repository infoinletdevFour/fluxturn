              "type": "string"
            }
          }
        }
      },
      {
        "id": "node_06_3",
        "type": "CONNECTOR_ACTION",
        "position": {
          "x": 700,
          "y": 100
        },
        "data": {
          "label": "Log Message",
          "category": "action",
          "config": {
