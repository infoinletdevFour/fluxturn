{
  "id": "89f54c09-92dc-4334-8dc7-9e73bbbd7c49",
  "name": "Shopify Order AI Summary",
  "description": "Generate AI-powered order summaries and insights using OpenAI",
  "category": "ecommerce",
  "difficulty": "intermediate",
  "estimatedSetupTime": "10 min",
  "requiredConnectors": ["shopify", "openai", "slack"],
  "canvas": {
    "nodes": [
      {
        "id": "shopify_trigger_1",
        "type": "CONNECTOR_TRIGGER",
        "position": { "x": 100, "y": 100 },
        "data": {
          "label": "New Shopify Order",
          "connector": "shopify",
          "triggerId": "order_created",
          "icon": "shopping-cart",
          "category": "trigger",
          "description": "Triggers when a new order is created",
          "config": {},
          "outputSchema": {
            "order_number": { "type": "string" },
            "line_items": { "type": "array" },
            "customer": { "type": "object" }
          }
        }
      },
      {
        "id": "openai_action_1",
        "type": "CONNECTOR_ACTION",
        "position": { "x": 400, "y": 100 },
        "data": {
          "label": "Generate AI Summary",
          "connector": "openai",
          "actionId": "chat_complete",
          "icon": "cpu",
          "category": "action",
          "description": "Generate order summary with OpenAI",
          "config": {
            "model": "gpt-4o-mini",
            "messages": [
              {
                "role": "system",
                "content": "You are an e-commerce analyst. Summarize order data concisely and provide one actionable insight."
              },
              {
                "role": "user",
                "content": "Summarize this Shopify order:\nOrder #{{$json.order_number}}\nCustomer: {{$json.customer.first_name}} {{$json.customer.last_name}}\nTotal: ${{$json.total_price}}\nItems: {{$json.line_items.map(i => i.title + ' x' + i.quantity).join(', ')}}\nShipping: {{$json.shipping_address.city}}, {{$json.shipping_address.country}}"
              }
            ]
          },
          "inputSchema": {
            "model": { "type": "string", "required": true, "label": "Model" },
            "messages": { "type": "array", "required": true, "label": "Messages" }
          },
          "outputSchema": {
            "content": { "type": "string" }
          }
        }
      },
      {
        "id": "slack_action_1",
        "type": "CONNECTOR_ACTION",
        "position": { "x": 700, "y": 100 },
        "data": {
          "label": "Post to Slack",
          "connector": "slack",
          "actionId": "send_message",
          "icon": "message-square",
          "category": "action",
          "description": "Share AI summary on Slack",
          "config": {
            "channel": "{{orders_channel}}",
            "text": "🤖 *AI Order Summary*\n\n{{$json.choices[0].message.content}}"
          },
          "inputSchema": {
            "channel": { "type": "string", "required": true, "label": "Channel" },
            "text": { "type": "string", "required": true, "label": "Message" }
          },
          "outputSchema": {
            "ts": { "type": "string" }
          }
        }
      }
    ],
    "edges": [
      {
        "id": "e1",
        "source": "shopify_trigger_1",
        "target": "openai_action_1",
        "sourceHandle": "source-1",
        "targetHandle": "target-1"
      },
      {
        "id": "e2",
        "source": "openai_action_1",
        "target": "slack_action_1",
        "sourceHandle": "source-1",
        "targetHandle": "target-1"
      }
    ]
  },
  "verified": false
}
