            "amount": { "type": "string" },
            "reason": { "type": "string" }
          }
        }
      },
      {
        "id": "slack_action_1",
        "type": "CONNECTOR_ACTION",
        "position": { "x": 450, "y": 100 },
        "data": {
          "label": "Alert Finance Team",
