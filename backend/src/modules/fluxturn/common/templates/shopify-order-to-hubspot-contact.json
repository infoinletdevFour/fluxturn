{
  "id": "3ada4787-8df2-41e6-b2f2-e3a9ae301122",
  "name": "Shopify Order to HubSpot Contact",
  "description": "Create or update HubSpot contacts from Shopify orders",
  "category": "ecommerce",
  "difficulty": "intermediate",
  "estimatedSetupTime": "10 min",
  "requiredConnectors": ["shopify", "hubspot"],
  "canvas": {
    "nodes": [
      {
        "id": "shopify_trigger_1",
        "type": "CONNECTOR_TRIGGER",
        "position": { "x": 100, "y": 100 },
        "data": {
          "label": "New Shopify Order",
          "connector": "shopify",
          "triggerId": "order_created",
          "icon": "shopping-cart",
          "category": "trigger",
          "description": "Triggers when a new order is created",
          "config": {},
          "outputSchema": {
            "customer": { "type": "object" },
            "total_price": { "type": "string" }
          }
        }
      },
      {
        "id": "hubspot_action_1",
        "type": "CONNECTOR_ACTION",
        "position": { "x": 450, "y": 100 },
        "data": {
          "label": "Create/Update HubSpot Contact",
          "connector": "hubspot",
          "actionId": "upsert_contact",
          "icon": "user-plus",
          "category": "action",
          "description": "Create or update contact in HubSpot",
          "config": {
            "email": "={{$json.customer.email}}",
            "properties": {
              "firstname": "={{$json.customer.first_name}}",
              "lastname": "={{$json.customer.last_name}}",
              "phone": "={{$json.customer.phone}}",
              "shopify_customer_id": "={{$json.customer.id}}",
              "last_order_value": "={{$json.total_price}}"
            }
          },
          "inputSchema": {
            "email": { "type": "string", "required": true, "label": "Email" },
            "properties": { "type": "object", "label": "Properties" }
          },
          "outputSchema": {
            "id": { "type": "string" }
          }
        }
      }
    ],
    "edges": [
      {
        "id": "e1",
        "source": "shopify_trigger_1",
        "target": "hubspot_action_1",
        "sourceHandle": "source-1",
        "targetHandle": "target-1"
      }
    ]
  },
  "verified": false
}
