{
  "id": "fe2fdd87-bdce-4148-878c-b18567dc396b",
  "name": "Shopify Order to Trello Card",
  "description": "Create Trello cards for new Shopify orders to track fulfillment",
  "category": "ecommerce",
  "difficulty": "beginner",
  "estimatedSetupTime": "10 min",
  "requiredConnectors": ["shopify", "trello"],
  "canvas": {
    "nodes": [
      {
        "id": "shopify_trigger_1",
        "type": "CONNECTOR_TRIGGER",
        "position": { "x": 100, "y": 100 },
        "data": {
          "label": "New Shopify Order",
          "connector": "shopify",
          "triggerId": "order_created",
          "icon": "shopping-cart",
          "category": "trigger",
          "description": "Triggers when a new order is created",
          "config": {},
          "outputSchema": {
            "order_number": { "type": "string" },
            "customer": { "type": "object" },
            "line_items": { "type": "array" }
          }
        }
      },
      {
        "id": "trello_action_1",
        "type": "CONNECTOR_ACTION",
        "position": { "x": 450, "y": 100 },
        "data": {
          "label": "Create Trello Card",
          "connector": "trello",
          "actionId": "card_add",
          "icon": "clipboard",
          "category": "action",
          "description": "Create a card for order tracking",
          "config": {
            "idList": "{{trello_list_id}}",
            "name": "Order #{{$json.order_number}} - {{$json.customer.first_name}} {{$json.customer.last_name}}",
            "desc": "Customer: {{$json.customer.email}}\nTotal: ${{$json.total_price}}\nItems: {{$json.line_items.length}}\n\nShipping Address:\n{{$json.shipping_address.address1}}\n{{$json.shipping_address.city}}, {{$json.shipping_address.province}} {{$json.shipping_address.zip}}"
          },
          "inputSchema": {
            "idList": { "type": "string", "required": true, "label": "List ID" },
            "name": { "type": "string", "required": true, "label": "Card Name" },
            "desc": { "type": "string", "label": "Description" }
          },
          "outputSchema": {
            "id": { "type": "string" }
          }
        }
      }
    ],
    "edges": [
      {
        "id": "e1",
        "source": "shopify_trigger_1",
        "target": "trello_action_1",
        "sourceHandle": "source-1",
        "targetHandle": "target-1"
      }
    ]
  },
  "verified": false
}
