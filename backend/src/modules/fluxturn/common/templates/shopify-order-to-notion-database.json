{
  "id": "ab3b749e-e398-449f-b4d0-2ac3d5d899d3",
  "name": "Shopify Orders to Notion Database",
  "description": "Automatically add Shopify orders to a Notion database",
  "category": "ecommerce",
  "difficulty": "intermediate",
  "estimatedSetupTime": "10 min",
  "requiredConnectors": ["shopify", "notion"],
  "canvas": {
    "nodes": [
      {
        "id": "shopify_trigger_1",
        "type": "CONNECTOR_TRIGGER",
        "position": { "x": 100, "y": 100 },
        "data": {
          "label": "New Shopify Order",
          "connector": "shopify",
          "triggerId": "order_created",
          "icon": "shopping-cart",
          "category": "trigger",
          "description": "Triggers when a new order is created",
          "config": {},
          "outputSchema": {
            "order_number": { "type": "string" },
            "customer": { "type": "object" },
            "total_price": { "type": "string" }
          }
        }
      },
      {
        "id": "notion_action_1",
        "type": "CONNECTOR_ACTION",
        "position": { "x": 450, "y": 100 },
        "data": {
          "label": "Create Notion Page",
          "connector": "notion",
          "actionId": "database_page_create",
          "icon": "file-plus",
          "category": "action",
          "description": "Create a new page in Notion database",
          "config": {
            "databaseId": "{{notion_database_id}}",
            "properties": {
              "Order Number": { "title": [{ "text": { "content": "={{$json.order_number}}" } }] },
              "Customer": { "rich_text": [{ "text": { "content": "={{$json.customer.first_name}} {{$json.customer.last_name}}" } }] },
              "Email": { "email": "={{$json.customer.email}}" },
              "Total": { "number": "={{parseFloat($json.total_price)}}" },
              "Status": { "select": { "name": "New" } }
            }
          },
          "inputSchema": {
            "databaseId": { "type": "string", "required": true, "label": "Database ID" },
            "properties": { "type": "object", "required": true, "label": "Properties" }
          },
          "outputSchema": {
            "id": { "type": "string" }
          }
        }
      }
    ],
    "edges": [
      {
        "id": "e1",
        "source": "shopify_trigger_1",
        "target": "notion_action_1",
        "sourceHandle": "source-1",
        "targetHandle": "target-1"
      }
    ]
  },
  "verified": false
}
