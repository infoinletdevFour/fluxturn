          },
          "inputSchema": {
            "channel": { "type": "string", "required": true, "label": "Channel" },
            "text": { "type": "string", "required": true, "label": "Message" }
          },
          "outputSchema": {
            "ts": { "type": "string" }
          }
        }
      }
    ],
    "edges": [
      {
        "id": "e1",
        "source": "shopify_trigger_1",
        "target": "slack_action_1",
        "sourceHandle": "source-1",
        "targetHandle": "target-1"
      }
    ]
