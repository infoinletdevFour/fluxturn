        "id": "shopify_trigger_1",
        "type": "CONNECTOR_TRIGGER",
        "position": { "x": 100, "y": 100 },
        "data": {
          "label": "New Product Created",
          "connector": "shopify",
          "triggerId": "product_created",
          "icon": "package",
          "category": "trigger",
          "description": "Triggers when a new product is created",
          "config": {},
          "outputSchema": {
            "id": { "type": "string" },
            "title": { "type": "string" },
            "vendor": { "type": "string" }
          }
        }
      },
      {
        "id": "slack_action_1",
        "type": "CONNECTOR_ACTION",
        "position": { "x": 450, "y": 100 },
        "data": {
          "label": "Notify Team",
          "connector": "slack",
          "actionId": "send_message",
          "icon": "message-square",
          "category": "action",
