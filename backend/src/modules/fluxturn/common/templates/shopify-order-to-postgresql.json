{
  "id": "eebfb1d7-e329-486e-9df5-5cb6be8ae730",
  "name": "Shopify Orders to PostgreSQL",
  "description": "Save Shopify orders to PostgreSQL for data warehousing",
  "category": "ecommerce",
  "difficulty": "intermediate",
  "estimatedSetupTime": "15 min",
  "requiredConnectors": ["shopify", "postgresql"],
  "canvas": {
    "nodes": [
      {
        "id": "shopify_trigger_1",
        "type": "CONNECTOR_TRIGGER",
        "position": { "x": 100, "y": 100 },
        "data": {
          "label": "New Shopify Order",
          "connector": "shopify",
          "triggerId": "order_created",
          "icon": "shopping-cart",
          "category": "trigger",
          "description": "Triggers when a new order is created",
          "config": {},
          "outputSchema": {
            "id": { "type": "string" },
            "order_number": { "type": "string" },
            "total_price": { "type": "string" }
          }
        }
      },
      {
        "id": "postgresql_action_1",
        "type": "CONNECTOR_ACTION",
        "position": { "x": 450, "y": 100 },
        "data": {
          "label": "Insert to PostgreSQL",
          "connector": "postgresql",
          "actionId": "insert_rows",
          "icon": "database",
          "category": "action",
          "description": "Insert order into PostgreSQL",
          "config": {
            "table": "orders",
            "columns": ["shopify_id", "order_number", "customer_email", "total_amount", "currency", "status", "created_at"],
            "values": [
              "={{$json.id}}",
              "={{$json.order_number}}",
              "={{$json.customer.email}}",
              "={{parseFloat($json.total_price)}}",
              "={{$json.currency}}",
              "={{$json.financial_status}}",
              "={{$json.created_at}}"
            ]
          },
          "inputSchema": {
            "table": { "type": "string", "required": true, "label": "Table Name" },
            "columns": { "type": "array", "required": true, "label": "Columns" },
            "values": { "type": "array", "required": true, "label": "Values" }
          },
          "outputSchema": {
            "rowCount": { "type": "number" }
          }
        }
      }
    ],
    "edges": [
      {
        "id": "e1",
        "source": "shopify_trigger_1",
        "target": "postgresql_action_1",
        "sourceHandle": "source-1",
        "targetHandle": "target-1"
      }
    ]
  },
  "verified": false
}
