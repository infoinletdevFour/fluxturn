{
  "id": "b1c97743-24c9-45c8-825c-6c8608881baf",
  "name": "Shopify Order to Stripe Invoice",
  "description": "Create Stripe invoices for Shopify B2B orders",
  "category": "ecommerce",
  "difficulty": "intermediate",
  "estimatedSetupTime": "15 min",
  "requiredConnectors": ["shopify", "stripe"],
  "canvas": {
    "nodes": [
      {
        "id": "shopify_trigger_1",
        "type": "CONNECTOR_TRIGGER",
        "position": { "x": 100, "y": 100 },
        "data": {
          "label": "New Shopify Order",
          "connector": "shopify",
          "triggerId": "order_created",
          "icon": "shopping-cart",
          "category": "trigger",
          "description": "Triggers when a new order is created",
          "config": {},
          "outputSchema": {
            "order_number": { "type": "string" },
            "customer": { "type": "object" },
            "total_price": { "type": "string" }
          }
        }
      },
      {
        "id": "stripe_action_1",
        "type": "CONNECTOR_ACTION",
        "position": { "x": 450, "y": 100 },
        "data": {
          "label": "Create Stripe Invoice",
          "connector": "stripe",
          "actionId": "charge_create",
          "icon": "credit-card",
          "category": "action",
          "description": "Create invoice in Stripe",
          "config": {
            "customer": "={{$json.customer.email}}",
            "amount": "={{Math.round(parseFloat($json.total_price) * 100)}}",
            "currency": "={{$json.currency.toLowerCase()}}",
            "description": "Shopify Order #{{$json.order_number}}",
            "metadata": {
              "shopify_order_id": "={{$json.id}}",
              "shopify_order_number": "={{$json.order_number}}"
            }
          },
          "inputSchema": {
            "customer": { "type": "string", "required": true, "label": "Customer" },
            "amount": { "type": "number", "required": true, "label": "Amount (cents)" },
            "currency": { "type": "string", "required": true, "label": "Currency" },
            "description": { "type": "string", "label": "Description" }
          },
          "outputSchema": {
            "id": { "type": "string" }
          }
        }
      }
    ],
    "edges": [
      {
        "id": "e1",
        "source": "shopify_trigger_1",
        "target": "stripe_action_1",
        "sourceHandle": "source-1",
        "targetHandle": "target-1"
      }
    ]
  },
  "verified": false
}
