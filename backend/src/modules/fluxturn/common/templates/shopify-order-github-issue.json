{
  "id": "facc4b68-172c-45b5-8d82-37465c3c1754",
  "name": "Shopify Order Issues to GitHub",
  "description": "Create GitHub issues for problematic Shopify orders",
  "category": "ecommerce",
  "difficulty": "intermediate",
  "estimatedSetupTime": "10 min",
  "requiredConnectors": ["shopify", "github"],
  "canvas": {
    "nodes": [
      {
        "id": "shopify_trigger_1",
        "type": "CONNECTOR_TRIGGER",
        "position": { "x": 100, "y": 100 },
        "data": {
          "label": "Order Updated",
          "connector": "shopify",
          "triggerId": "order_updated",
          "icon": "shopping-cart",
          "category": "trigger",
          "description": "Triggers when an order is updated",
          "config": {
            "status": "cancelled"
          },
          "outputSchema": {
            "order_number": { "type": "string" },
            "cancel_reason": { "type": "string" }
          }
        }
      },
      {
        "id": "github_action_1",
        "type": "CONNECTOR_ACTION",
        "position": { "x": 450, "y": 100 },
        "data": {
          "label": "Create GitHub Issue",
          "connector": "github",
          "actionId": "create_issue",
          "icon": "alert-circle",
          "category": "action",
          "description": "Create issue for cancelled order investigation",
          "config": {
            "owner": "{{github_owner}}",
            "repo": "{{github_repo}}",
            "title": "Cancelled Order #{{$json.order_number}} - Investigation Required",
            "body": "## Order Cancelled\n\n**Order Number:** {{$json.order_number}}\n**Cancel Reason:** {{$json.cancel_reason}}\n**Customer:** {{$json.customer.email}}\n**Total:** ${{$json.total_price}}\n\n### Action Required\n- [ ] Review cancellation reason\n- [ ] Contact customer if needed\n- [ ] Process refund\n- [ ] Update inventory",
            "labels": ["order-issue", "needs-review"]
          },
          "inputSchema": {
            "owner": { "type": "string", "required": true, "label": "Owner" },
            "repo": { "type": "string", "required": true, "label": "Repository" },
            "title": { "type": "string", "required": true, "label": "Title" },
            "body": { "type": "string", "label": "Body" },
            "labels": { "type": "array", "label": "Labels" }
          },
          "outputSchema": {
            "number": { "type": "number" },
            "html_url": { "type": "string" }
          }
        }
      }
    ],
    "edges": [
      {
        "id": "e1",
        "source": "shopify_trigger_1",
        "target": "github_action_1",
        "sourceHandle": "source-1",
        "targetHandle": "target-1"
      }
    ]
  },
  "verified": false
}
