{
  "id": "f5e0a48a-6726-4c68-a6b9-b3ada93f102a",
  "name": "Shopify Order Confirmation via SendGrid",
  "description": "Send professional order confirmation emails via SendGrid",
  "category": "ecommerce",
  "difficulty": "beginner",
  "estimatedSetupTime": "10 min",
  "requiredConnectors": ["shopify", "sendgrid"],
  "canvas": {
    "nodes": [
      {
        "id": "shopify_trigger_1",
        "type": "CONNECTOR_TRIGGER",
        "position": { "x": 100, "y": 100 },
        "data": {
          "label": "New Shopify Order",
          "connector": "shopify",
          "triggerId": "order_created",
          "icon": "shopping-cart",
          "category": "trigger",
          "description": "Triggers when a new order is created",
          "config": {},
          "outputSchema": {
            "order_number": { "type": "string" },
            "customer": { "type": "object" },
            "total_price": { "type": "string" }
          }
        }
      },
      {
        "id": "sendgrid_action_1",
        "type": "CONNECTOR_ACTION",
        "position": { "x": 450, "y": 100 },
        "data": {
          "label": "Send Confirmation Email",
          "connector": "sendgrid",
          "actionId": "send_email",
          "icon": "mail",
          "category": "action",
          "description": "Send order confirmation via SendGrid",
          "config": {
            "to": "={{$json.customer.email}}",
            "from": "{{store_email}}",
            "subject": "Order Confirmed - #{{$json.order_number}}",
            "html": "<h1>Thank you for your order!</h1><p>Order #{{$json.order_number}}</p><p>Total: ${{$json.total_price}}</p><p>We'll notify you when your order ships.</p>"
          },
          "inputSchema": {
            "to": { "type": "string", "required": true, "label": "To" },
            "from": { "type": "string", "required": true, "label": "From" },
            "subject": { "type": "string", "required": true, "label": "Subject" },
            "html": { "type": "string", "label": "HTML Content" }
          },
          "outputSchema": {
            "messageId": { "type": "string" }
          }
        }
      }
    ],
    "edges": [
      {
        "id": "e1",
        "source": "shopify_trigger_1",
        "target": "sendgrid_action_1",
        "sourceHandle": "source-1",
        "targetHandle": "target-1"
      }
    ]
  },
  "verified": false
}
