{
  "id": "8bb79149-4495-47bc-9301-8f9c7c7fc87f",
  "name": "Shopify Products Sync to Airtable",
  "description": "Sync Shopify product catalog to Airtable for inventory management",
  "category": "ecommerce",
  "difficulty": "intermediate",
  "estimatedSetupTime": "10 min",
  "requiredConnectors": ["shopify", "airtable"],
  "canvas": {
    "nodes": [
      {
        "id": "shopify_action_1",
        "type": "CONNECTOR_ACTION",
        "position": { "x": 100, "y": 100 },
        "data": {
          "label": "Get All Products",
          "connector": "shopify",
          "actionId": "get_all_products",
          "icon": "package",
          "category": "action",
          "description": "Retrieve all products from Shopify",
          "config": {
            "returnAll": true
          },
          "inputSchema": {
            "returnAll": { "type": "boolean", "label": "Return All", "default": true }
          },
          "outputSchema": {
            "products": { "type": "array" }
          }
        }
      },
      {
        "id": "airtable_action_1",
        "type": "CONNECTOR_ACTION",
        "position": { "x": 450, "y": 100 },
        "data": {
          "label": "Create Airtable Records",
          "connector": "airtable",
          "actionId": "create_record",
          "icon": "database",
          "category": "action",
          "description": "Create product records in Airtable",
          "config": {
            "baseId": "{{airtable_base_id}}",
            "tableId": "Products",
            "fields": {
              "Product ID": "={{$json.id}}",
              "Title": "={{$json.title}}",
              "Vendor": "={{$json.vendor}}",
              "Type": "={{$json.product_type}}",
              "Price": "={{$json.variants[0].price}}",
              "SKU": "={{$json.variants[0].sku}}"
            }
          },
          "inputSchema": {
            "baseId": { "type": "string", "required": true, "label": "Base ID" },
            "tableId": { "type": "string", "required": true, "label": "Table ID" },
            "fields": { "type": "object", "required": true, "label": "Fields" }
          },
          "outputSchema": {
            "id": { "type": "string" }
          }
        }
      }
    ],
    "edges": [
      {
        "id": "e1",
        "source": "shopify_action_1",
        "target": "airtable_action_1",
        "sourceHandle": "source-1",
        "targetHandle": "target-1"
      }
    ]
  },
  "verified": false
}
