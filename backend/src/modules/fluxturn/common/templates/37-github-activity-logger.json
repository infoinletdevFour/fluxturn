{
  "id": "b20fa0fd-5af9-485d-8fbf-1ecaab275de5",
  "name": "GitHub Activity Logger",
  "description": "Log GitHub repository activity to sheets",
  "category": "data",
  "difficulty": "beginner",
  "estimatedSetupTime": "10 min",
  "requiredConnectors": [
    "github",
    "google_sheets",
    "slack"
  ],
  "canvas": {
    "nodes": [
      {
        "id": "node_37_1",
        "type": "CONNECTOR_TRIGGER",
        "position": {
          "x": 100,
          "y": 100
        },
        "data": {
          "label": "Code Push",
          "category": "trigger",
          "config": {
            "repository": "{{your_repo}}"
          },
          "connector": "github",
          "triggerId": "push",
          "inputSchema": {
            "pollInterval": {
              "type": "number",
              "label": "Poll Interval",
              "default": 300
            }
          },
          "configSchema": {
            "pollInterval": {
              "type": "number",
              "label": "Poll Interval",
              "default": 300
            }
          },
          "outputSchema": {
            "data": {
              "type": "object",
              "description": "Trigger event data"
            }
          }
        }
      },
      {
        "id": "node_37_2",
        "type": "CONNECTOR_ACTION",
        "position": {
          "x": 400,
          "y": 100
        },
        "data": {
          "label": "Log Activity",
          "category": "action",
          "config": {
            "spreadsheetId": "{{your_sheet_id}}",
            "values": "={{$json}}"
          },
          "connector": "google_sheets",
          "actionId": "append_row",
          "action": "append_row",
          "actionName": "Append Row",
          "description": "Append a row to a Google Sheet",
          "icon": "table",
          "connectorType": "google_sheets",
          "connectorDisplayName": "Google Sheets",
          "inputSchema": {
            "spreadsheetId": {
              "type": "string",
              "required": true,
              "label": "Spreadsheet ID"
            },
            "sheetName": {
              "type": "string",
              "label": "Sheet Name",
              "default": "Sheet1"
            },
            "values": {
              "type": "object",
              "required": true,
              "label": "Values"
            }
          },
          "configSchema": {
            "spreadsheetId": {
              "type": "string",
              "required": true,
              "label": "Spreadsheet ID"
            },
            "sheetName": {
              "type": "string",
              "label": "Sheet Name",
              "default": "Sheet1"
            },
            "values": {
              "type": "object",
              "required": true,
              "label": "Values"
            }
          },
          "outputSchema": {
            "rowNumber": {
              "type": "number"
            }
          }
        }
      },
      {
        "id": "node_37_3",
        "type": "CONNECTOR_ACTION",
        "position": {
          "x": 700,
          "y": 100
        },
        "data": {
          "label": "Notify Team",
          "category": "action",
          "config": {
            "channel": "#dev",
            "message": "💻 New push by {{$json.pusher.name}}: {{$json.commits.length}} commits"
          },
          "connector": "slack",
          "actionId": "send_message",
          "action": "send_message",
          "actionName": "Send Message",
          "description": "Send a message to a Slack channel",
          "icon": "send",
          "connectorType": "slack",
          "connectorDisplayName": "Slack",
          "inputSchema": {
            "channel": {
              "type": "string",
              "required": true,
              "label": "Channel"
            },
            "message": {
              "type": "string",
              "required": true,
              "label": "Message",
              "inputType": "textarea"
            }
          },
          "configSchema": {
            "channel": {
              "type": "string",
              "required": true,
              "label": "Channel"
            },
            "message": {
              "type": "string",
              "required": true,
              "label": "Message",
              "inputType": "textarea"
            }
          },
          "outputSchema": {
            "messageId": {
              "type": "string"
            }
          }
        }
      }
    ],
    "edges": [
      {
        "id": "e_1",
        "source": "node_37_1",
        "target": "node_37_2",
        "sourceHandle": "source-1",
        "targetHandle": "target-1"
      },
      {
        "id": "e_2",
        "source": "node_37_2",
        "target": "node_37_3",
        "sourceHandle": "source-1",
        "targetHandle": "target-1"
      }
    ]
  },
  "verified": false
