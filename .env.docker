# =====================================================
# FLUXTURN - DOCKER COMPOSE DEFAULTS
# =====================================================
# This file provides sensible defaults for running FluxTurn
# with `docker compose up`. Copy and customize as needed.
# =====================================================

# ─── Database ────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fluxturn_platform
POSTGRES_PORT=5433

# ─── Redis ───────────────────────────────────────────
REDIS_PORT=6379

# ─── Qdrant ──────────────────────────────────────────
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# ─── Backend ─────────────────────────────────────────
BACKEND_PORT=5005
JWT_SECRET=change-me-in-production-use-openssl-rand-hex-64
SESSION_SECRET=change-me-in-production
CONNECTOR_ENCRYPTION_KEY=change-me-in-production-use-openssl-rand-hex-32

# ─── Frontend ────────────────────────────────────────
FRONTEND_PORT=5185

# ─── Optional: AI Services ───────────────────────────
# OPENAI_API_KEY=your-openai-api-key
# AI_PROVIDER=openai

# ─── Optional: Email ─────────────────────────────────
# MAIL_HOST=smtp.your-provider.com
# MAIL_PORT=587
# MAIL_USERNAME=your-smtp-username
# MAIL_PASSWORD=your-smtp-password

# ─── Optional: Cloud Storage ─────────────────────────
# CLOUDFLARE_ACCOUNT_ID=your-account-id
# CLOUDFLARE_R2_ACCESS_KEY_ID=your-access-key
# CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-secret-key
